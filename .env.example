# --- DATABASE CONFIGURATION ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartlearn_db

# --- BACKEND AUTH CONFIGURATION ---
SECRET_KEY=super-secret-key-for-smartlearn-lms-development-only
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTO_CREATE_TABLES=false

# --- FRONTEND CONFIGURATION ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- EMAIL SERVICE (SMTP) CONFIGURATION ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username@gmail.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=your-smtp-username@gmail.com
SMTP_FROM_NAME=SmartLearn LMS
SMTP_USE_TLS=true
DEBUG=true
ENVIRONMENT=development

